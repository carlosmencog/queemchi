<section id="benefits" data-qm-section="benefits" class="tw-bg-white tw-px-5 tw-py-16 md:tw-py-24">
  <div class="tw-mx-auto tw-max-w-7xl">
    <div data-qm-reveal class="tw-mx-auto tw-max-w-3xl tw-text-center">
      <p class="tw-text-sm tw-font-extrabold tw-uppercase tw-tracking-[0.18em] tw-text-[#e98080]">{{ section.settings.eyebrow | escape }}</p>
      <h2 class="tw-mt-4 tw-text-4xl tw-font-black tw-leading-tight tw-text-[#e03d54] md:tw-text-6xl">{{ section.settings.heading | escape }}</h2>
      <div class="tw-mt-6 tw-text-lg tw-leading-8 tw-text-[#7a2932]">{{ section.settings.text }}</div>
    </div>
    <div class="tw-mt-12 tw-grid tw-gap-5 md:tw-grid-cols-3">
      {% for block in section.blocks %}
        <article data-qm-card class="tw-group tw-rounded-[2rem] tw-bg-[#fff7f5] tw-p-6 tw-shadow-sm tw-transition hover:-tw-translate-y-1 hover:tw-shadow-xl" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 700 | image_tag: loading: 'lazy', class: 'tw-mb-6 tw-aspect-[4/3] tw-w-full tw-rounded-3xl tw-object-cover', alt: block.settings.title }}
          {% endif %}
          <h3 class="tw-text-2xl tw-font-black tw-leading-tight tw-text-[#e03d54]">{{ block.settings.title | escape }}</h3>
          <p class="tw-mt-4 tw-text-base tw-leading-7 tw-text-[#7a2932]">{{ block.settings.text | escape }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Queemchi beneficios",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Beneficios" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Es hora de darle más vida a tu comida." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Fermentamos cada lote con paciencia para lograr un kimchi fresco, balanceado y lleno de sabor.</p>" }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Sabor vivo" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Picante, ácido, umami y crujiente para transformar cualquier plato." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Queemchi beneficios",
      "blocks": [
        { "type": "benefit" },
        { "type": "benefit" },
        { "type": "benefit" }
      ]
    }
  ]
}
{% endschema %}
