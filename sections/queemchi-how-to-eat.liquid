<section id="como-consumirlo-{{ section.id }}" data-qm-section="how-to-eat" class="tw-bg-white tw-px-5 tw-py-16 md:tw-py-24">
  <div class="tw-mx-auto tw-max-w-7xl">
    <div data-qm-reveal class="tw-flex tw-flex-col tw-gap-6 md:tw-flex-row md:tw-items-end md:tw-justify-between">
      <div class="tw-max-w-3xl">
        <p class="tw-text-sm tw-font-extrabold tw-uppercase tw-tracking-[0.18em] tw-text-[#e98080]">{{ section.settings.eyebrow | escape }}</p>
        <h2 class="tw-mt-4 tw-text-4xl tw-font-black tw-leading-tight tw-text-[#e03d54] md:tw-text-6xl">{{ section.settings.heading | escape }}</h2>
      </div>
      <div class="tw-max-w-md tw-text-base tw-leading-7 tw-text-[#7a2932]">{{ section.settings.text }}</div>
    </div>
    <div class="tw-mt-10 tw-flex tw-gap-4 tw-overflow-x-auto tw-pb-4">
      {% for block in section.blocks %}
        <article data-qm-card class="tw-min-w-[260px] tw-flex-1 tw-rounded-[2rem] tw-bg-[#fff7f5] tw-p-5" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 700 | image_tag: loading: 'lazy', class: 'tw-aspect-square tw-w-full tw-rounded-3xl tw-object-cover', alt: block.settings.title }}
          {% endif %}
          <h3 class="tw-mt-5 tw-text-2xl tw-font-black tw-text-[#e03d54]">{{ block.settings.title | escape }}</h3>
          <p class="tw-mt-2 tw-text-sm tw-leading-6 tw-text-[#7a2932]">{{ block.settings.text | escape }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Queemchi cómo consumirlo",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Cómo consumirlo" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Una cucharada puede cambiar todo un plato." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>No necesitas ser experto en comida coreana. Abre el frasco, sirve una cucharada y dale carácter a cualquier comida.</p>" }
  ],
  "blocks": [
    {
      "type": "idea",
      "name": "Serving idea",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Bowls" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Arroz, vegetales, proteína y una cucharada de Queemchi." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Queemchi cómo consumirlo",
      "blocks": [
        { "type": "idea" },
        { "type": "idea" },
        { "type": "idea" },
        { "type": "idea" }
      ]
    }
  ]
}
{% endschema %}
