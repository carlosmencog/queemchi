<section id="coming-soon-{{ section.id }}" data-qm-section="coming-soon" class="tw-bg-[#fff7f5] tw-px-5 tw-py-16 md:tw-py-24">
  <div class="tw-mx-auto tw-grid tw-max-w-7xl tw-overflow-hidden tw-rounded-[2.5rem] tw-bg-[#e03d54] tw-text-white md:tw-grid-cols-2">
    <div data-qm-reveal class="tw-p-8 md:tw-p-12 lg:tw-p-16">
      <p class="tw-text-sm tw-font-extrabold tw-uppercase tw-tracking-[0.18em] tw-text-[#f5a79e]">{{ section.settings.eyebrow | escape }}</p>
      <h2 class="tw-mt-4 tw-text-4xl tw-font-black tw-leading-tight md:tw-text-6xl">{{ section.settings.heading | escape }}</h2>
      <div class="tw-mt-6 tw-text-lg tw-leading-8 tw-text-white/90">{{ section.settings.text }}</div>
      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link | default: '#' }}" class="tw-mt-8 tw-inline-flex tw-rounded-full tw-bg-white tw-px-7 tw-py-4 tw-font-extrabold tw-text-[#e03d54] hover:tw-bg-[#f5a79e]">{{ section.settings.button_label | escape }}</a>
      {% endif %}
    </div>
    <div data-qm-reveal class="tw-min-h-80">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'tw-h-full tw-w-full tw-object-cover', alt: section.settings.heading }}
      {% else %}
        <div class="tw-flex tw-h-full tw-min-h-80 tw-items-center tw-justify-center tw-bg-[#f5a79e] tw-text-7xl tw-font-black tw-text-[#e03d54]">Soon</div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Queemchi coming soon",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Coming soon" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Más fermentos están en camino." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Nuevas versiones, sabores de temporada y productos vivos para seguir explorando la mesa.</p>" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Avísame cuando salga" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [
    { "name": "Queemchi coming soon" }
  ]
}
{% endschema %}
