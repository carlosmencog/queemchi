<section id="fermentacion-{{ section.id }}" data-qm-section="fermentation" class="tw-bg-[#e03d54] tw-px-5 tw-py-16 tw-text-white md:tw-py-24">
  <div class="tw-mx-auto tw-grid tw-max-w-7xl tw-gap-10 lg:tw-grid-cols-[0.9fr_1.1fr] lg:tw-items-center">
    <div data-qm-reveal>
      <p class="tw-text-sm tw-font-extrabold tw-uppercase tw-tracking-[0.18em] tw-text-[#f5a79e]">{{ section.settings.eyebrow | escape }}</p>
      <h2 class="tw-mt-4 tw-text-4xl tw-font-black tw-leading-tight md:tw-text-6xl">{{ section.settings.heading | escape }}</h2>
      <div class="tw-mt-6 tw-text-lg tw-leading-8 tw-text-white/90">{{ section.settings.text }}</div>
    </div>
    <div class="tw-grid tw-gap-4 sm:tw-grid-cols-3">
      {% for block in section.blocks %}
        <article data-qm-card class="tw-rounded-[2rem] tw-bg-white/12 tw-p-6 tw-backdrop-blur" {{ block.shopify_attributes }}>
          <div class="tw-mb-8 tw-flex tw-h-14 tw-w-14 tw-items-center tw-justify-center tw-rounded-full tw-bg-[#f5a79e] tw-text-xl tw-font-black tw-text-[#e03d54]">{{ forloop.index }}</div>
          <h3 class="tw-text-xl tw-font-black">{{ block.settings.title | escape }}</h3>
          <p class="tw-mt-3 tw-text-sm tw-leading-6 tw-text-white/85">{{ block.settings.text | escape }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Queemchi fermentación",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Ingredientes / fermentación" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Un proceso vivo, sin atajos." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Nuestro kimchi se prepara en lotes pequeños, se fermenta naturalmente y se prueba antes de salir.</p>" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Preparar" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Cortamos, salamos y sazonamos con cuidado." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Queemchi fermentación",
      "blocks": [
        { "type": "step" },
        { "type": "step" },
        { "type": "step" }
      ]
    }
  ]
}
{% endschema %}
