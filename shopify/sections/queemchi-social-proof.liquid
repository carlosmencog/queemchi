<section id="comunidad-{{ section.id }}" data-qm-section="social-proof" class="tw-bg-[#e98080] tw-px-5 tw-py-16 tw-text-white md:tw-py-24">
  <div class="tw-mx-auto tw-max-w-7xl">
    <div data-qm-reveal class="tw-mx-auto tw-max-w-3xl tw-text-center">
      <p class="tw-text-sm tw-font-extrabold tw-uppercase tw-tracking-[0.18em] tw-text-white/80">{{ section.settings.eyebrow | escape }}</p>
      <h2 class="tw-mt-4 tw-text-4xl tw-font-black tw-leading-tight md:tw-text-6xl">{{ section.settings.heading | escape }}</h2>
    </div>
    <div class="tw-mt-12 tw-grid tw-gap-5 md:tw-grid-cols-3">
      {% for block in section.blocks %}
        <figure data-qm-card class="tw-rounded-[2rem] tw-bg-white tw-p-6 tw-text-[#7a2932]" {{ block.shopify_attributes }}>
          <blockquote class="tw-text-xl tw-font-bold tw-leading-8">“{{ block.settings.quote | escape }}”</blockquote>
          <figcaption class="tw-mt-8 tw-flex tw-items-center tw-gap-4">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 160 | image_tag: loading: 'lazy', class: 'tw-h-14 tw-w-14 tw-rounded-full tw-object-cover', alt: block.settings.name }}
            {% else %}
              <div class="tw-h-14 tw-w-14 tw-rounded-full tw-bg-[#f5a79e]"></div>
            {% endif %}
            <div>
              <p class="tw-font-black tw-text-[#e03d54]">{{ block.settings.name | escape }}</p>
              <p class="tw-text-sm tw-text-[#7a2932]/75">{{ block.settings.role | escape }}</p>
            </div>
          </figcaption>
        </figure>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Queemchi social proof",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Comunidad" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "La gente ya lo está poniendo en todo." }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "Queemchi me hizo entender que comer saludable no tiene que saber aburrido." },
        { "type": "text", "id": "name", "label": "Name", "default": "Cliente Queemchi" },
        { "type": "text", "id": "role", "label": "Role", "default": "Medellín" },
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Queemchi social proof",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
