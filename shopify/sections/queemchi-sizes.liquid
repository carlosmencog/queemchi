<section id="pricing" data-qm-section="sizes" class="tw-bg-[#fff7f5] tw-px-5 tw-py-16 md:tw-py-24">
  <div class="tw-mx-auto tw-max-w-7xl">
    <div data-qm-reveal class="tw-mx-auto tw-max-w-3xl tw-text-center">
      <p class="tw-text-sm tw-font-extrabold tw-uppercase tw-tracking-[0.18em] tw-text-[#e98080]">{{ section.settings.eyebrow | escape }}</p>
      <h2 class="tw-mt-4 tw-text-4xl tw-font-black tw-leading-tight tw-text-[#e03d54] md:tw-text-6xl">{{ section.settings.heading | escape }}</h2>
    </div>
    <div class="tw-mt-12 tw-grid tw-gap-5 md:tw-grid-cols-3">
      {% for block in section.blocks %}
        <article data-qm-card class="tw-flex tw-min-h-72 tw-flex-col tw-rounded-[2rem] tw-bg-white tw-p-6 tw-shadow-sm" {{ block.shopify_attributes }}>
          <h3 class="tw-text-3xl tw-font-black tw-text-[#e03d54]">{{ block.settings.title | escape }}</h3>
          <p class="tw-mt-3 tw-text-base tw-leading-7 tw-text-[#7a2932]">{{ block.settings.text | escape }}</p>
          {% if block.settings.product != blank %}
            <p class="tw-mt-5 tw-text-lg tw-font-black tw-text-[#e98080]">{{ block.settings.product.price | money }}</p>
          {% endif %}
          <div class="tw-mt-auto tw-pt-8">
            {% assign button_link = block.settings.link %}
            {% if block.settings.product != blank %}
              {% assign button_link = block.settings.product.url %}
            {% endif %}
            <a href="{{ button_link | default: '#' }}" class="tw-inline-flex tw-w-full tw-justify-center tw-rounded-full tw-bg-[#e03d54] tw-px-6 tw-py-4 tw-font-extrabold tw-text-white hover:tw-bg-[#c83045]">{{ block.settings.button_label | escape }}</a>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Queemchi tamaños",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Presentaciones" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Kimchi para probar, repetir y compartir." }
  ],
  "blocks": [
    {
      "type": "size",
      "name": "Size",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Personal" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Para quienes quieren empezar o sumar kimchi a pocas comidas por semana." },
        { "type": "product", "id": "product", "label": "Linked product" },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "Quiero el mío" },
        { "type": "url", "id": "link", "label": "Fallback link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Queemchi tamaños",
      "blocks": [
        { "type": "size" },
        { "type": "size" },
        { "type": "size" }
      ]
    }
  ]
}
{% endschema %}
